/* 大屏模式 — 深色主题 */
#bigscreenInterface { border: none; }

/* ═══ 分割条 ═══ */
QSplitter::handle:vertical {
    height: 8px;
    background: qlineargradient(x1:0, y1:0.5, x2:1, y2:0.5,
        stop:0 transparent, stop:0.05 transparent,
        stop:0.10 rgba(255, 255, 255, 0.08),
        stop:0.50 rgba(255, 255, 255, 0.15),
        stop:0.90 rgba(255, 255, 255, 0.08),
        stop:0.95 transparent, stop:1 transparent);
    border: none;
    margin: 0 16px;
    image: none;
}

/* ═══ 标题栏 ═══ */
#headerBar {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #1a2744, stop:1 #16213e);
    border: 1px solid #2d3f60;
    border-radius: 10px;
}
#headerTitle {
    color: #e2e8f0;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 1px;
}

/* 徽章 */
#badgeOnline, #badgeAccount, #badgeUptime {
    background-color: rgba(30, 41, 59, 0.9);
    border: 1px solid #3b5280;
    border-radius: 8px;
    padding: 2px 4px;
}
#badgeOnline { border-color: #22c55e; }
#badgeAccount { border-color: #3b82f6; }
#badgeUptime { border-color: #a78bfa; }
#badgeText {
    color: #cbd5e1;
    font-size: 12px;
    font-weight: 600;
}

/* ═══ 账号池面板 ═══ */
#accountPanel {
    background-color: rgba(15, 23, 42, 0.95);
    border: 1px solid #1e3a5f;
    border-radius: 10px;
}
#panelTitle {
    color: #cbd5e1;
    font-size: 14px;
    font-weight: bold;
}
#poolStats {
    color: #64748b;
    font-size: 11px;
    font-weight: 500;
}

/* ═══ 操作按钮面板 ═══ */
#actionPanel {
    background-color: rgba(15, 23, 42, 0.95);
    border: 1px solid #1e3a5f;
    border-radius: 10px;
}
#actionPanel PushButton {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1e3355, stop:1 #162544);
    color: #cbd5e1;
    border: 1px solid #2d4a6f;
    border-radius: 8px;
    padding: 8px 14px;
    font-weight: 600;
    font-size: 13px;
}
#actionPanel PushButton:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #243d6a, stop:1 #1e3355);
    border-color: #3b82f6;
    color: #93c5fd;
}
#actionPanel PushButton:pressed {
    background-color: #0f172a;
    border-color: #3b82f6;
}

/* ═══ 统计卡片（复用） ═══ */
#statCard {
    border-radius: 10px;
    background-color: rgba(39, 39, 39, 0.95);
    border: 1px solid rgb(60, 60, 60);
}
#statTitle { color: rgb(170, 170, 170); font-size: 12px; }
#statValue { color: white; font-size: 28px; font-weight: bold; }

/* 危险按钮 hover */
#btnRebootPC:hover, #btnStopExe:hover, #btnDeleteFile:hover {
    border-color: #ef4444;
    color: #fca5a5;
}
